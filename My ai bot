from transformers import pipeline
import wikipedia

# Tit paj la
st.title("🤖 IA Chatbot Konesans")
st.subheader("Mande m nenpòt bagay, m ap reponn ou!")

# Chaje modèl la (ak caching pou li pa chaje chak fwa)
@st.cache_resource
def load_model():
    return pipeline("question-answering", model="deepset/xlm-roberta-base-squad2")

qa_pipeline = load_model()
wikipedia.set_lang("en")

# Chan pou antre done
sije = st.text_input("Sou ki sijè ou vle poze kesyon?")
kesyon = st.text_input("Ki kesyon ou genyen?")

if st.button("Poze Kesyon"):
    if sije and kesyon:
        with st.spinner('M ap chèche nan Wikipedia...'):
            try:
                konteks = wikipedia.summary(sije, sentences=3)
                rezilta = qa_pipeline(question=kesyon, context=konteks)
                
                st.success(f"Repons: {rezilta['answer']}")
                st.write(f"Konfyans: {round(rezilta['score']*100, 1)}%")
            except Exception as e:
                st.error("Mwen pa jwenn enfòmasyon sa a oswa gen yon erè.")
    else:
        st.warning("Tanpri ranpli tou de bwat yo.")
